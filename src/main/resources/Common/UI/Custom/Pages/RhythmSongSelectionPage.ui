$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 1080, Height: 700);

  #Title {
    Group {
      $C.@Title {
        @Text = "Rhythm Song Select";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group #SelectionContainer {
      LayoutMode: Left;
      Anchor: (Height: 585);

      Group #SongPane {
        Anchor: (Width: 350, Height: 585);
        LayoutMode: Top;

        Label {
          Text: "Songs";
          Style: (
            FontSize: 18,
            RenderUppercase: true,
            RenderBold: true
          );
          Anchor: (Bottom: 8);
        }

        Group #SongList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
        }
      }

      Group #ChartPane {
        Anchor: (Width: 350, Height: 585);
        LayoutMode: Top;
        Padding: (Left: 12);

        Label {
          Text: "Charts";
          Style: (
            FontSize: 18,
            RenderUppercase: true,
            RenderBold: true
          );
          Anchor: (Bottom: 8);
        }

        Group #ChartList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
        }
      }

      Group #SongInfo {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Left: 16);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Label #SongTitle {
          Style: (
            FontSize: 24,
            RenderUppercase: true,
            RenderBold: true
          );
          Anchor: (Bottom: 4);
        }

        Label #SongArtist {
          Style: (
            FontSize: 16,
            TextColor: #bcbcbc
          );
          Anchor: (Bottom: 10);
        }

        Label #SessionSummary {
          Style: (
            FontSize: 14,
            TextColor: #919191
          );
          Anchor: (Bottom: 16);
        }

        Label #DifficultyName {
          Anchor: (Bottom: 6);
        }

        Label #ChartIdentifier {
          Anchor: (Bottom: 6);
        }

        Label #KeyMode {
          Anchor: (Bottom: 6);
        }

        Label #NoteSummary {
          Anchor: (Bottom: 6);
        }

        Label #SourceName {
          Anchor: (Bottom: 14);
        }

        Label #StatusText {
          Style: (
            FontSize: 15,
            TextColor: #d6d6d6
          );
        }
      }
    }

    Group #Actions {
      Anchor: (Top: 12);
      LayoutMode: Right;

      TextButton #ConfirmButton {
        Padding: (Full: 6);
        Style: $C.@DefaultTextButtonStyle;
      }

      TextButton #CancelButton {
        Padding: (Full: 6);
        Style: $C.@DefaultTextButtonStyle;
      }
    }
  }
}
